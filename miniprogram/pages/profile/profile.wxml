<!--pages/profile/profile.wxml - 我的-->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-card" bindtap="loginIfNeeded">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
      <view class="user-level" wx:if="{{userInfo}}">
        <text class="level-badge">Lv.{{level}}</text>
        <text class="level-text">{{levelTitle}}</text>
      </view>
    </view>
    <view class="ach-entry" bindtap="goAchievement">
      <text class="ach-count">{{achievementCount}}</text>
      <text class="ach-label">成就</text>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="data-card">
    <view class="data-cell">
      <text class="data-num">{{totalBills}}</text>
      <text class="data-label">总账单</text>
    </view>
    <view class="data-cell">
      <text class="data-num">{{streakDays}}</text>
      <text class="data-label">连续记账</text>
    </view>
    <view class="data-cell">
      <text class="data-num">{{ledgerCount}}</text>
      <text class="data-label">共享账本</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="goRemind">
      <view class="menu-icon">⏰</view>
      <text class="menu-text">记账提醒</text>
      <text class="menu-value">{{remindText}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goLedger">
      <view class="menu-icon">👥</view>
      <text class="menu-text">共享账本</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAchievement">
      <view class="menu-icon">🏆</view>
      <text class="menu-text">我的成就</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goCategory">
      <view class="menu-icon">🏷️</view>
      <text class="menu-text">分类管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="exportData">
      <view class="menu-icon">📤</view>
      <text class="menu-text">导出账单</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearData">
      <view class="menu-icon danger">🗑️</view>
      <text class="menu-text danger">清空数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="showAbout">
      <view class="menu-icon">ℹ️</view>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="footer-tip">记账小程序 v1.0.0 · 让每一笔都有迹可循</view>
  <view class="bottom-spacer"></view>
</view>

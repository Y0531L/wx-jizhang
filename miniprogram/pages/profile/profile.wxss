/* pages/profile/profile.wxss */
.page { min-height: 100vh; padding-bottom: 40rpx; }

.user-card {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8e53 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.2);
}
.user-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  background: #ffffff;
  margin-right: 24rpx;
}
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}
.user-level {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.level-badge {
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(255,255,255,0.25);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}
.level-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
}
.ach-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.ach-count {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}
.ach-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

.data-card {
  display: flex;
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 0;
}
.data-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.data-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.data-label {
  font-size: 22rpx;
  color: #9aa0a6;
  margin-top: 6rpx;
}

.menu-group {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #fafafa;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  width: 56rpx;
  font-size: 36rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}
.menu-text.danger { color: #ff3b30; }
.menu-icon.danger { opacity: 1; }
.menu-value {
  font-size: 24rpx;
  color: #9aa0a6;
  margin-right: 12rpx;
}
.menu-arrow {
  font-size: 32rpx;
  color: #c4c7c5;
}

.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #c4c7c5;
  padding: 32rpx 0;
}
.bottom-spacer { height: 40rpx; }

/* pages/bills/bills.wxss */
.page { min-height: 100vh; padding-bottom: 40rpx; }

.month-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #ffffff;
  gap: 60rpx;
}
.month-arrow {
  font-size: 44rpx;
  color: #9aa0a6;
  width: 60rpx;
  text-align: center;
  line-height: 1;
}
.month-display {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.summary-bar {
  display: flex;
  background: #ffffff;
  padding: 0 24rpx 32rpx;
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.summary-label {
  font-size: 22rpx;
  color: #9aa0a6;
  margin-bottom: 8rpx;
}
.summary-value {
  font-size: 30rpx;
  font-weight: 600;
}
.summary-divider {
  width: 1rpx;
  background: #f0f0f0;
}

.filter-bar {
  display: flex;
  margin: 24rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  padding: 6rpx;
}
.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #5f6368;
  border-radius: 12rpx;
}
.filter-tab.active {
  background: #ffffff;
  color: #ff6b35;
  font-weight: 600;
}

.day-group {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}
.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.day-date {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}
.day-sum {
  font-size: 22rpx;
  color: #9aa0a6;
}
.bill-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #fafafa;
}
.bill-item:last-child {
  border-bottom: none;
}
.bill-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f6f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.bill-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.bill-category {
  font-size: 28rpx;
  color: #1a1a1a;
}
.bill-note {
  font-size: 22rpx;
  color: #9aa0a6;
}
.bill-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}
.bill-amount {
  font-size: 30rpx;
  font-weight: 600;
}
.bill-source {
  font-size: 20rpx;
  color: #1a73e8;
  background: #f0f7ff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 26rpx; color: #9aa0a6; }
.bottom-spacer { height: 40rpx; }

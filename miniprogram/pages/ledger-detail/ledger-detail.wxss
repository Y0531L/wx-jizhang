/* pages/ledger-detail/ledger-detail.wxss */
.page { min-height: 100vh; padding-bottom: 40rpx; }

.ledger-header {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #fff5f0 0%, #ffffff 100%);
  border-radius: 24rpx;
}
.ledger-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}
.ledger-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.ledger-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.ledger-code {
  font-size: 24rpx;
  color: #9aa0a6;
}
.invite-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8e53 100%);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.stat-bar {
  display: flex;
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 0;
}
.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.stat-label {
  font-size: 22rpx;
  color: #9aa0a6;
  margin-top: 6rpx;
}

.section {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}
.section-title {
  font-size: 26rpx;
  color: #9aa0a6;
  padding: 24rpx 28rpx 16rpx;
}
.member-list { padding: 0 28rpx 16rpx; }
.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #fafafa;
}
.member-item:last-child { border-bottom: none; }
.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 20rpx;
}
.member-info { flex: 1; }
.member-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.member-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}
.member-tag {
  font-size: 20rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.member-tag.me {
  color: #1a73e8;
  background: #f0f7ff;
}
.member-sub {
  font-size: 22rpx;
  color: #9aa0a6;
  margin-top: 6rpx;
  display: block;
}
.member-action {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #ff3b30;
  background: #fff0f0;
  border-radius: 24rpx;
}

.bill-list { padding: 0 28rpx 16rpx; }
.bill-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #fafafa;
}
.bill-item:last-child { border-bottom: none; }
.bill-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f6f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}
.bill-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.bill-category { font-size: 28rpx; color: #1a1a1a; }
.bill-author { font-size: 22rpx; color: #9aa0a6; }
.bill-amount { font-size: 30rpx; font-weight: 600; }

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #fafafa;
  font-size: 28rpx;
  color: #1a1a1a;
}
.setting-item:last-child { border-bottom: none; }
.setting-item.danger { color: #ff3b30; }
.arrow { color: #c4c7c5; font-size: 32rpx; }

/* 邀请弹窗 */
.invite-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 48rpx;
}
.invite-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}
.invite-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  font-size: 44rpx;
  color: #c4c7c5;
  padding: 12rpx;
  line-height: 1;
}
.invite-ledger {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}
.invite-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff5f0 0%, #ffe8de 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.invite-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.invite-tip {
  font-size: 26rpx;
  color: #5f6368;
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.invite-code-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}
.invite-code {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6b35;
  letter-spacing: 4rpx;
  font-family: monospace;
}
.invite-copy {
  padding: 12rpx 24rpx;
  background: #ff6b35;
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 24rpx;
}
.invite-members {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}
.invite-member-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  margin-left: -16rpx;
  background: #f0f0f0;
}
.invite-member-avatar:first-child { margin-left: 0; }
.invite-share-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8e53 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin-bottom: 16rpx;
  padding: 0;
}
.invite-share-btn::after { border: none; }
.invite-share-tip {
  font-size: 22rpx;
  color: #9aa0a6;
}

.empty-mini { text-align: center; color: #9aa0a6; font-size: 26rpx; padding: 40rpx 0; }
.bottom-spacer { height: 40rpx; }

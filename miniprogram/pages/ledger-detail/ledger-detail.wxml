<!--pages/ledger-detail/ledger-detail.wxml - 账本详情-->
<view class="page">
  <!-- 账本信息 -->
  <view class="ledger-header">
    <view class="ledger-icon">{{ledger.icon || '👥'}}</view>
    <view class="ledger-meta">
      <text class="ledger-name">{{ledger.name}}</text>
      <text class="ledger-code">邀请码：{{ledger.code}}</text>
    </view>
    <view class="invite-btn" bindtap="showInvite">邀请</view>
  </view>

  <!-- 统计 -->
  <view class="stat-bar">
    <view class="stat-cell">
      <text class="stat-num">{{ledger.memberCount || 0}}</text>
      <text class="stat-label">成员</text>
    </view>
    <view class="stat-cell">
      <text class="stat-num">{{ledger.billCount || 0}}</text>
      <text class="stat-label">账单</text>
    </view>
    <view class="stat-cell">
      <text class="stat-num expense-color">¥{{totalExpense}}</text>
      <text class="stat-label">总支出</text>
    </view>
  </view>

  <!-- 成员列表 -->
  <view class="section">
    <view class="section-title">成员管理</view>
    <view class="member-list">
      <view class="member-item" wx:for="{{members}}" wx:key="openid">
        <image class="member-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}"></image>
        <view class="member-info">
          <view class="member-name-row">
            <text class="member-name">{{item.nickName || '匿名'}}</text>
            <text class="member-tag" wx:if="{{item.role === 'owner'}}">创建者</text>
            <text class="member-tag me" wx:if="{{item.isMe}}">我</text>
          </view>
          <text class="member-sub">记账 {{item.billCount}} 笔</text>
        </view>
        <view class="member-action" wx:if="{{isOwner && !item.isMe}}" bindtap="removeMember" data-openid="{{item.openid}}">
          <text>移除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 最近共享账单 -->
  <view class="section">
    <view class="section-title">共享账单</view>
    <view class="bill-list" wx:if="{{bills.length > 0}}">
      <view class="bill-item" wx:for="{{bills}}" wx:key="_id">
        <view class="bill-icon">{{item.categoryIcon}}</view>
        <view class="bill-info">
          <text class="bill-category">{{item.categoryName}}</text>
          <text class="bill-author">{{item.authorName}} · {{item.timeText}}</text>
        </view>
        <text class="bill-amount {{item.type === 'income' ? 'income-color' : 'expense-color'}}">
          {{item.type === 'income' ? '+' : '-'}}¥{{item.amountText}}
        </text>
      </view>
    </view>
    <view class="empty-mini" wx:else>暂无共享账单</view>
  </view>

  <!-- 设置 -->
  <view class="section">
    <view class="setting-item" bindtap="rename" wx:if="{{isOwner}}">
      <text>重命名账本</text>
      <text class="arrow">›</text>
    </view>
    <view class="setting-item danger" bindtap="exitLedger" wx:if="{{!isOwner}}">
      <text>退出账本</text>
      <text class="arrow">›</text>
    </view>
    <view class="setting-item danger" bindtap="dissolveLedger" wx:if="{{isOwner}}">
      <text>解散账本</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 邀请弹窗 -->
  <view class="invite-mask" wx:if="{{showInviteModal}}" bindtap="closeInviteModal">
    <view class="invite-modal" catchtap="noop">
      <view class="invite-close" bindtap="closeInviteModal">×</view>
      <view class="invite-ledger">
        <view class="invite-icon">{{ledger.icon || '👥'}}</view>
        <text class="invite-name">{{ledger.name || '共享账本'}}</text>
      </view>
      <text class="invite-tip">{{inviteTip}}</text>
      <view class="invite-code-box">
        <text class="invite-code">{{ledger.code}}</text>
        <view class="invite-copy" bindtap="copyCode">复制</view>
      </view>
      <view class="invite-members" wx:if="{{members.length > 0}}">
        <image class="invite-member-avatar" wx:for="{{members}}" wx:key="openid" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <button class="invite-share-btn" open-type="share" bindtap="closeInviteModal">邀请好友加入</button>
      <text class="invite-share-tip">点击按钮，选择微信好友加入账本</text>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>

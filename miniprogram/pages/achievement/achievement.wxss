/* pages/achievement/achievement.wxss */
.page { min-height: 100vh; padding-bottom: 40rpx; }

.level-card {
  position: relative;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.15);
}
.level-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8e53 50%, #ffb74d 100%);
}
.level-content {
  position: relative;
  padding: 40rpx 36rpx;
}
.level-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.level-badge {
  display: flex;
  flex-direction: column;
}
.level-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}
.level-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
}
.level-stats {
  display: flex;
  gap: 32rpx;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}
.stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}
.progress-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.progress-bar {
  height: 16rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 8rpx;
  transition: width 0.3s;
}
.progress-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
}

.ach-section {
  margin: 0 24rpx 32rpx;
}
.ach-group-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}
.ach-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.ach-item {
  width: calc((100% - 20rpx) / 2);
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.ach-item.unlocked {
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 53, 0.12);
  border: 1rpx solid #ffe0c0;
}
.ach-item.locked {
  opacity: 0.65;
}
.ach-icon-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 16rpx;
}
.ach-icon {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  background: #fff5f0;
  border-radius: 50%;
}
.ach-item.locked .ach-icon {
  filter: grayscale(1);
}
.ach-lock {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  font-size: 28rpx;
}
.ach-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}
.ach-desc {
  font-size: 22rpx;
  color: #9aa0a6;
  text-align: center;
  width: 100%;
}
.ach-progress {
  width: 100%;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-top: 16rpx;
  overflow: hidden;
}
.ach-progress-fill {
  height: 100%;
  background: #ff6b35;
  border-radius: 4rpx;
}
.bottom-spacer { height: 40rpx; }

/* pages/ledger/ledger.wxss */
.page { min-height: 100vh; padding: 24rpx; }

.page-header {
  padding: 16rpx 8rpx 32rpx;
}
.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}
.page-desc {
  font-size: 24rpx;
  color: #9aa0a6;
  margin-top: 8rpx;
  display: block;
}

.ledger-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.ledger-card.personal {
  background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%);
  border: 1rpx solid #d0e3ff;
}
.ledger-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #f5f6f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.ledger-card.personal .ledger-icon {
  background: #e3f0ff;
}
.ledger-info {
  flex: 1;
  min-width: 0;
}
.ledger-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.ledger-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.ledger-tag {
  font-size: 20rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.ledger-sub {
  font-size: 24rpx;
  color: #9aa0a6;
}
.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.member-avatars {
  display: flex;
}
.member-avatars .member-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  margin-left: -12rpx;
  background: #f0f0f0;
}
.member-avatars .member-avatar:first-child {
  margin-left: 0;
}
.ledger-arrow {
  font-size: 40rpx;
  color: #c4c7c5;
  margin-left: 16rpx;
}

.section-label {
  font-size: 26rpx;
  color: #9aa0a6;
  padding: 24rpx 8rpx 16rpx;
}

.create-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  background: #ffffff;
  border: 2rpx dashed #ffd9c0;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  gap: 12rpx;
}
.create-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff5f0;
  color: #ff6b35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  line-height: 48rpx;
}
.create-text {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 500;
}

.join-tip {
  text-align: center;
  padding: 32rpx 0;
}
.join-text {
  font-size: 26rpx;
  color: #5f6368;
}
.bottom-spacer { height: 40rpx; }

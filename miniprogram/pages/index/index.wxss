/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 概览卡片 */
.overview-card {
  position: relative;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.12);
}
.overview-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #fff5f0 0%, #ffffff 60%);
}
.overview-content {
  position: relative;
  padding: 40rpx 36rpx;
}
.month-label {
  font-size: 26rpx;
  color: #9aa0a6;
  margin-bottom: 24rpx;
}
.balance-row {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}
.balance-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.balance-item.net {
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 1rpx solid #ffe8dc;
}
.balance-label {
  font-size: 24rpx;
  color: #9aa0a6;
  margin-bottom: 8rpx;
}
.balance-item.net .balance-label {
  margin-bottom: 0;
}
.balance-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.balance-divider {
  width: 1rpx;
  height: 60rpx;
  background: #f0f0f0;
  margin: 0 24rpx;
}

/* 待补记提醒 */
.remind-card {
  margin: 0 24rpx 24rpx;
  background: #fff8f0;
  border: 1rpx solid #ffe0c0;
  border-radius: 20rpx;
  padding: 28rpx;
}
.remind-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}
.remind-title {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 600;
}
.remind-tip {
  font-size: 22rpx;
  color: #b8784a;
  margin-top: 6rpx;
}
.remind-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.remind-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.remind-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.remind-platform {
  font-size: 26rpx;
  color: #1a1a1a;
  background: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.remind-amount {
  font-size: 30rpx;
  font-weight: 600;
}
.remind-time {
  font-size: 24rpx;
  color: #9aa0a6;
}

/* 快捷功能 */
.quick-grid {
  display: flex;
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 0;
}
.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #f5f6f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}
.quick-text {
  font-size: 24rpx;
  color: #5f6368;
}

/* 最近账单 */
.recent-section {
  margin: 0 24rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.section-more {
  font-size: 24rpx;
  color: #9aa0a6;
}

/* 账单项 */
.bill-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}
.bill-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f6f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.bill-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.bill-category {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}
.bill-note {
  font-size: 22rpx;
  color: #9aa0a6;
}
.bill-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}
.bill-amount {
  font-size: 32rpx;
  font-weight: 600;
}
.bill-time {
  font-size: 22rpx;
  color: #9aa0a6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 26rpx;
  color: #9aa0a6;
}

.bottom-spacer {
  height: 120rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b35 0%, #ff8e53 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  z-index: 100;
}
.fab-icon {
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 56rpx;
}

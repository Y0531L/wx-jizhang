/* pages/stats/stats.wxss */
.page { min-height: 100vh; padding-bottom: 40rpx; }

.seg-tabs {
  display: flex;
  background: #f0f0f0;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 6rpx;
}
.seg-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #5f6368;
  border-radius: 12rpx;
}
.seg-tab.active {
  background: #ffffff;
  color: #ff6b35;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}

/* 柱状图 */
.chart-bars {
  display: flex;
  align-items: flex-end;
  height: 280rpx;
  gap: 16rpx;
}
.bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}
.bar-track {
  width: 100%;
  height: 220rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.bar-fill {
  width: 70%;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s;
}
.bar-value {
  font-size: 20rpx;
  color: #5f6368;
  margin-top: 8rpx;
}
.bar-label {
  font-size: 20rpx;
  color: #9aa0a6;
}

/* 环形图 */
.pie-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.pie-wrap {
  margin-bottom: 32rpx;
}
.pie {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pie-hole {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.pie-total-label {
  font-size: 22rpx;
  color: #9aa0a6;
}
.pie-total-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-top: 4rpx;
}
.legend {
  width: 100%;
}
.legend-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #fafafa;
}
.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}
.legend-name {
  flex: 1;
  font-size: 26rpx;
  color: #1a1a1a;
}
.legend-percent {
  font-size: 24rpx;
  color: #5f6368;
  margin-right: 24rpx;
}
.legend-amount {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

/* 对比 */
.compare-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #fafafa;
}
.compare-row:last-child { border-bottom: none; }
.compare-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #5f6368;
}
.compare-bars {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.compare-bar-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.compare-bar {
  height: 16rpx;
  border-radius: 8rpx;
  min-width: 8rpx;
}
.compare-amt {
  font-size: 22rpx;
}

.expense-bg { background: #ff3b30; }
.income-bg { background: #34c759; }
.empty-mini {
  text-align: center;
  color: #9aa0a6;
  font-size: 26rpx;
  padding: 40rpx 0;
}

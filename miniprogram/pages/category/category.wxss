/* pages/category/category.wxss */
.page { min-height: 100vh; padding: 24rpx; }
.seg-tabs {
  display: flex;
  background: #f0f0f0;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}
.seg-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #5f6368;
  border-radius: 12rpx;
}
.seg-tab.active {
  background: #ffffff;
  color: #ff6b35;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.cat-list {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.cat-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #fafafa;
}
.cat-item:last-child { border-bottom: none; }
.cat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f5f6f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}
.cat-name { flex: 1; font-size: 28rpx; color: #1a1a1a; }
.cat-tag {
  font-size: 20rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}
.cat-delete {
  font-size: 24rpx;
  color: #ff3b30;
  padding: 8rpx 20rpx;
  background: #fff0f0;
  border-radius: 20rpx;
}
.add-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background: #ffffff;
  border: 2rpx dashed #ffd9c0;
  border-radius: 20rpx;
  gap: 12rpx;
}
.add-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #fff5f0;
  color: #ff6b35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 40rpx;
}
.add-text { font-size: 28rpx; color: #ff6b35; }
.bottom-spacer { height: 40rpx; }
